# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# --- Entornos virtuales ---
.venv/
venv/
env/

# --- Datos (se generan con el pipeline) ---
data/raw/
data/processed/

# --- Modelos entrenados y artefactos binarios ---
experiments/*.pkl
experiments/mlruns/
experiments/predicciones_produccion.jsonl

# --- MLflow artifacts ---
mlruns/

# --- Jupyter checkpoints ---
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# --- pdfs-ppts: excluir material externo y scripts de generación ---
pdfs-ppts/assets/
pdfs-ppts/cotent/
pdfs-ppts/sample/
pdfs-ppts/generar_presentacion.py
pdfs-ppts/generar_ppt_notebooks.py

# --- Docker ---
*.dockerignore

# --- IDE ---
.idea/
.vscode/
*.iml

# --- OS ---
.DS_Store
Thumbs.db
*.tmp
*.log

# --- Scripts locales ---
start.cmd

# --- Node / npm (herramientas locales de presentacion) ---
node_modules/
package.json
package-lock.json

# --- Outputs generados ---
output/

# --- MLflow experiment artifacts (binarios grandes) ---
experiments/169775168716009235/
experiments/741316909501968302/
experiments/ab_log.jsonl
experiments/ab_resultado.json
experiments/batch_output/*.csv
experiments/batch_output/*.json
experiments/model_card.json
experiments/model_card.md
experiments/models/

# --- Scripts temporales de generacion de PPTs ---
pdfs-ppts/fix_*.py
pdfs-ppts/ejecutar_*.py
pdfs-ppts/crear_nb*.py
pdfs-ppts/capturar_imagenes.py
pdfs-ppts/content/
pdfs-ppts/output/mlops_ejemplo_notebooks_v2.pptx

# --- Certificados ---
*.crt

# --- Archivos temporales PowerPoint ---
~$*.pptx
~$*.xlsx

# .gitignore
.env
.env.*