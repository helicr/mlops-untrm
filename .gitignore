# ============================================================
# .gitignore — MLOps: Ciclo de Vida del Modelo
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# --- Entornos virtuales ---
.venv/
venv/
env/

# --- Datos (se generan con el pipeline) ---
data/raw/
data/processed/

# --- Modelos entrenados y artefactos binarios ---
experiments/*.pkl
experiments/mlruns/
experiments/predicciones_produccion.jsonl

# --- MLflow artifacts ---
mlruns/

# --- Jupyter checkpoints ---
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# --- pdfs-ppts: excluir material externo y scripts de generación ---
pdfs-ppts/assets/
pdfs-ppts/cotent/
pdfs-ppts/sample/
pdfs-ppts/generar_presentacion.py
pdfs-ppts/generar_ppt_notebooks.py

# --- Docker ---
*.dockerignore

# --- IDE ---
.idea/
.vscode/
*.iml

# --- OS ---
.DS_Store
Thumbs.db
*.tmp
*.log

# --- Scripts locales ---
start.cmd

# --- Certificados ---
*.crt

# --- Archivos temporales PowerPoint ---
~$*.pptx
~$*.xlsx

# .gitignore
.env
.env.*